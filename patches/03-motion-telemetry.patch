diff --git a/examples/simple_repeater/MyMesh.cpp b/examples/simple_repeater/MyMesh.cpp
index 24e8894..10e9df6 100644
--- a/examples/simple_repeater/MyMesh.cpp
+++ b/examples/simple_repeater/MyMesh.cpp
@@ -258,6 +258,21 @@ int MyMesh::handleRequest(ClientInfo *sender, uint32_t sender_timestamp, uint8_t
       telemetry.addTemperature(TELEM_CHANNEL_SELF, temperature); // Built-in MCU Temperature
     }
 
+#ifdef MOTION_TELEMETRY_ENABLED
+    // Ch 10: analog 10-bit (0-1023, 0-3.6V range)
+    analogReadResolution(10);
+    int raw10 = analogRead(MOTION_TELEM_PIN);
+    telemetry.addAnalogInput(10, (float)raw10);
+
+    // Ch 11: analog 14-bit (0-16383, 0-3.6V range)
+    analogReadResolution(14);
+    int raw14 = analogRead(MOTION_TELEM_PIN);
+    telemetry.addAnalogInput(11, (float)raw14);
+
+    // Ch 12: digital read (0 or 1)
+    telemetry.addDigitalInput(12, digitalRead(MOTION_TELEM_PIN));
+#endif
+
     uint8_t tlen = telemetry.getSize();
     memcpy(&reply_data[4], telemetry.getBuffer(), tlen);
     return 4 + tlen; // reply_len
@@ -928,6 +943,10 @@ void MyMesh::begin(FILESYSTEM *fs) {
 
   board.setAdcMultiplier(_prefs.adc_multiplier);
 
+#ifdef MOTION_TELEMETRY_ENABLED
+  analogCalibrateOffset();
+#endif
+
 #if ENV_INCLUDE_GPS == 1
   applyGpsPrefs();
 #endif
