+#ifdef MOTION_DETECT_ENABLED
+// LPCOMP ISR — fires on threshold crossing, just records timestamp for debounce
+static volatile unsigned long _lpcomp_last_irq = 0;
+extern "C" void LPCOMP_IRQHandler(void) {
+  if (NRF_LPCOMP->EVENTS_CROSS) {
+    NRF_LPCOMP->EVENTS_CROSS = 0;
+    _lpcomp_last_irq = millis();
+  }
+  if (NRF_LPCOMP->EVENTS_DOWN) NRF_LPCOMP->EVENTS_DOWN = 0;
+  if (NRF_LPCOMP->EVENTS_UP) NRF_LPCOMP->EVENTS_UP = 0;
+}
+
+void MyMesh::initMotionDetect() {
+  NRF_LPCOMP->ENABLE = LPCOMP_ENABLE_ENABLE_Disabled;
+  NRF_LPCOMP->PSEL = MOTION_LPCOMP_AIN;
+  NRF_LPCOMP->REFSEL = LPCOMP_REFSEL_REFSEL_SupplyTwoEighthsPrescaling;  // VDD*2/8 ~825mV
+  NRF_LPCOMP->ANADETECT = LPCOMP_ANADETECT_ANADETECT_Cross;
+  NRF_LPCOMP->HYST = LPCOMP_HYST_HYST_Hyst50mV;
+  NRF_LPCOMP->INTENSET = LPCOMP_INTENSET_CROSS_Msk;
+  NRF_LPCOMP->ENABLE = LPCOMP_ENABLE_ENABLE_Enabled;
+  NRF_LPCOMP->TASKS_START = 1;
+  NVIC_SetPriority(LPCOMP_IRQn, 6);
+  NVIC_ClearPendingIRQ(LPCOMP_IRQn);
+  NVIC_EnableIRQ(LPCOMP_IRQn);
+
+  // Read initial state: RESULT 0=below ref (motion on), 1=above ref (idle)
+  NRF_LPCOMP->TASKS_SAMPLE = 1;
+  while (!NRF_LPCOMP->EVENTS_READY) {}
+  NRF_LPCOMP->EVENTS_READY = 0;
+  _motion_on = (NRF_LPCOMP->RESULT == 0);
+  _motion_prev = _motion_on;
+  _motion_last_change = 0;
+  _motion_cooldown = 0;
+  MESH_DEBUG_PRINTLN("Motion detect: LPCOMP AIN%d, ref=VDD*2/8, debounce=%dms, initial=%s",
+                     MOTION_LPCOMP_AIN, MOTION_DEBOUNCE_MS, _motion_on ? "ON" : "OFF");
+}
+
+void MyMesh::initMotionChannel() {
+  const uint8_t key[] = MOTION_CHANNEL_KEY;
+  memset(_motion_channel.secret, 0, PUB_KEY_SIZE);
+  memcpy(_motion_channel.secret, key, 16);
+  mesh::Utils::sha256(_motion_channel.hash, PATH_HASH_SIZE, _motion_channel.secret, 16);
+  MESH_DEBUG_PRINTLN("Motion channel: %s", MOTION_CHANNEL_NAME);
+}
+
+void MyMesh::sendMotionAlert() {
+  uint32_t timestamp = getRTCClock()->getCurrentTime();
+  uint8_t temp[5 + 80];
+  memcpy(temp, &timestamp, 4);
+  temp[4] = TXT_TYPE_PLAIN;
+  char msg[64];
+  snprintf(msg, sizeof(msg), "%s: Motion detected", _prefs.node_name);
+  int msg_len = strlen(msg);
+  memcpy(&temp[5], msg, msg_len);
+
+  auto pkt = createGroupDatagram(PAYLOAD_TYPE_GRP_TXT, _motion_channel, temp, 5 + msg_len);
+  if (pkt) {
+    sendFlood(pkt);
+    MESH_DEBUG_PRINTLN("Motion alert sent to %s", MOTION_CHANNEL_NAME);
+  }
+}
+
+void MyMesh::checkMotionState() {
+  NRF_LPCOMP->TASKS_SAMPLE = 1;
+  bool current = (NRF_LPCOMP->RESULT == 0);  // 0=below ref=motion on
+
+  // Debounce: only accept change if stable for MOTION_DEBOUNCE_MS since last IRQ
+  if (current != _motion_on) {
+    unsigned long last_irq = _lpcomp_last_irq;
+    if (millis() - last_irq >= MOTION_DEBOUNCE_MS) {
+      _motion_prev = _motion_on;
+      _motion_on = current;
+      _motion_last_change = millis();
+
+      // Send alert on rising edge (OFF -> ON) with cooldown
+      if (_motion_on && !_motion_prev) {
+        if (!_motion_cooldown || millisHasNowPassed(_motion_cooldown)) {
+          sendMotionAlert();
+          _motion_cooldown = futureMillis(MOTION_COOLDOWN_MS);
+        }
+      }
+    }
+  }
+}
+#endif
