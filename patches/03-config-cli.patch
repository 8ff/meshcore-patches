diff --git a/src/helpers/ConfigCLI.cpp b/src/helpers/ConfigCLI.cpp
new file mode 100644
index 0000000..77651cd
--- /dev/null
+++ b/src/helpers/ConfigCLI.cpp
@@ -0,0 +1,278 @@
+#ifdef CONFIG_CLI_ENABLED
+
+#include "ConfigCLI.h"
+#include <string.h>
+#include <stdio.h>
+#include <MeshCore.h>
+
+static uint32_t _cfg_atoi(const char* sp) {
+  uint32_t n = 0;
+  while (*sp && *sp >= '0' && *sp <= '9') {
+    n *= 10;
+    n += (*sp++ - '0');
+  }
+  return n;
+}
+
+static float _cfg_atof(const char* sp) {
+  float result = 0.0f;
+  float sign = 1.0f;
+  if (*sp == '-') { sign = -1.0f; sp++; }
+  while (*sp >= '0' && *sp <= '9') {
+    result = result * 10.0f + (*sp++ - '0');
+  }
+  if (*sp == '.') {
+    sp++;
+    float frac = 0.1f;
+    while (*sp >= '0' && *sp <= '9') {
+      result += (*sp++ - '0') * frac;
+      frac *= 0.1f;
+    }
+  }
+  return result * sign;
+}
+
+static const char* _skip_ws(const char* s) {
+  while (*s == ' ' || *s == '\t') s++;
+  return s;
+}
+
+static char _lower(char c) { return (c >= 'A' && c <= 'Z') ? c + 32 : c; }
+
+// Case-insensitive prefix match: does input match at least min_len chars of target?
+static bool _pmatch(const char* input, int input_len, const char* target, int min_len) {
+  int tlen = strlen(target);
+  if (input_len < min_len || input_len > tlen) return false;
+  for (int i = 0; i < input_len; i++) {
+    if (_lower(input[i]) != target[i]) return false;
+  }
+  return true;
+}
+
+static void _format_uptime(char* buf, int max_len, uint32_t secs) {
+  uint32_t d = secs / 86400;
+  uint32_t h = (secs % 86400) / 3600;
+  uint32_t m = (secs % 3600) / 60;
+  if (d > 0) snprintf(buf, max_len, "%lud%luh%lum", (unsigned long)d, (unsigned long)h, (unsigned long)m);
+  else if (h > 0) snprintf(buf, max_len, "%luh%lum", (unsigned long)h, (unsigned long)m);
+  else snprintf(buf, max_len, "%lum", (unsigned long)m);
+}
+
+// Extract first word length (up to space/tab/end). Does NOT copy — just returns length.
+static int _word_len(const char* s, int max) {
+  int i = 0;
+  while (i < max && s[i] && s[i] != ' ' && s[i] != '\t') i++;
+  return i;
+}
+
+// Get pointer to args after the first word (skip word + whitespace)
+static const char* _get_args(const char* s, int slen) {
+  int i = 0;
+  while (i < slen && s[i] && s[i] != ' ' && s[i] != '\t') i++;
+  while (i < slen && (s[i] == ' ' || s[i] == '\t')) i++;
+  return &s[i];
+}
+
+enum {
+  CMD_NONE = 0,
+  CMD_HELP, CMD_STATUS, CMD_CONFIG, CMD_VER, CMD_TELEM,
+  CMD_FREQ, CMD_BW, CMD_SF, CMD_CR, CMD_POWER, CMD_NAME, CMD_REPEAT,
+  CMD_ADVERT, CMD_REBOOT,
+  CMD_AMBIGUOUS
+};
+
+static int _match_cmd(const char* word, int wlen) {
+  if (wlen == 1 && word[0] == '?') return CMD_HELP;
+
+  char w0 = _lower(word[0]);
+  char w1 = wlen >= 2 ? _lower(word[1]) : 0;
+
+  if (_pmatch(word, wlen, "help", 1)) return CMD_HELP;
+  if (_pmatch(word, wlen, "status", 1)) return CMD_STATUS;
+  if (_pmatch(word, wlen, "ver", 1)) return CMD_VER;
+  if (_pmatch(word, wlen, "telem", 1)) return CMD_TELEM;
+
+  // c alone = config, cr = coding rate, co+ = config
+  if (wlen == 1 && w0 == 'c') return CMD_CONFIG;
+  if (wlen >= 2 && w0 == 'c' && w1 == 'r') return CMD_CR;
+  if (wlen >= 2 && w0 == 'c' && w1 == 'o') return CMD_CONFIG;
+
+  if (_pmatch(word, wlen, "freq", 1)) return CMD_FREQ;
+  if (_pmatch(word, wlen, "bw", 1)) return CMD_BW;
+  if (wlen >= 2 && w0 == 's' && w1 == 'f') return CMD_SF;
+  if (_pmatch(word, wlen, "power", 1)) return CMD_POWER;
+  if (_pmatch(word, wlen, "name", 1)) return CMD_NAME;
+  if (_pmatch(word, wlen, "advert", 1)) return CMD_ADVERT;
+
+  if (wlen >= 2 && w0 == 'r' && w1 == 'e') {
+    if (wlen == 2) return CMD_AMBIGUOUS;
+    if (_pmatch(word, wlen, "reboot", 3)) return CMD_REBOOT;
+    if (_pmatch(word, wlen, "repeat", 3)) return CMD_REPEAT;
+  }
+
+  return CMD_NONE;
+}
+
+int configCLI_handleCommand(const char* cmd, char* reply, int max_len,
+                            ConfigCLIParams* params, ConfigCLIActions* actions) {
+  cmd = _skip_ws(cmd);
+  if (!cmd || !*cmd) return 0;
+
+  // Trim trailing whitespace
+  int len = strlen(cmd);
+  while (len > 0 && (cmd[len-1] <= ' ')) len--;
+  if (len == 0) return 0;
+
+  // Get first word and args (no copies — just pointers into cmd)
+  int wlen = _word_len(cmd, len);
+  const char* args = _get_args(cmd, len);
+
+  MESH_DEBUG_PRINTLN("ConfigCLI: word='%.*s' args='%s'", wlen, cmd, args);
+
+  // Handle "set X Y" — re-parse subcommand
+  if (wlen == 3 && _pmatch(cmd, 3, "set", 3)) {
+    args = _skip_ws(args);
+    cmd = args;
+    len = strlen(cmd);
+    wlen = _word_len(cmd, len);
+    args = _get_args(cmd, len);
+  }
+
+  // Handle "get config"
+  if (wlen == 3 && _pmatch(cmd, 3, "get", 3)) {
+    const char* sub = _skip_ws(args);
+    int swlen = _word_len(sub, strlen(sub));
+    if (_pmatch(sub, swlen, "config", 1)) {
+      return configCLI_handleCommand("config", reply, max_len, params, actions);
+    }
+  }
+
+  int id = _match_cmd(cmd, wlen);
+
+  switch (id) {
+    case CMD_HELP:
+      return snprintf(reply, max_len,
+        "? s c v t f b sf cr p n%s a[dvert] reb[oot]",
+        params->client_repeat ? " rep[eat]" : "");
+
+    case CMD_STATUS: {
+      char up[24];
+      _format_uptime(up, sizeof(up), params->uptime_secs);
+      return snprintf(reply, max_len,
+        "Batt:%umV Up:%s Air:%lus/%lus Pkts:%lu/%luF %lu/%luD Q:%d/%d C:%d",
+        (unsigned)params->batt_mv, up,
+        (unsigned long)params->total_air_secs, (unsigned long)params->rx_air_secs,
+        (unsigned long)params->n_sent_flood, (unsigned long)params->n_recv_flood,
+        (unsigned long)params->n_sent_direct, (unsigned long)params->n_recv_direct,
+        params->free_queue, params->total_queue, params->num_contacts);
+    }
+
+    case CMD_CONFIG:
+      return snprintf(reply, max_len,
+        "n:%s f:%.3f b:%.1f sf:%u cr:%u p:%ddBm af:%.1f%s",
+        params->node_name,
+        (double)*params->freq, (double)*params->bw,
+        (unsigned)*params->sf, (unsigned)*params->cr,
+        (int)*params->tx_power_dbm, (double)*params->airtime_factor,
+        (params->client_repeat && *params->client_repeat) ? " rpt:on" :
+        (params->client_repeat ? " rpt:off" : ""));
+
+    case CMD_VER:
+      return snprintf(reply, max_len, "%s (%s)",
+                      params->firmware_ver ? params->firmware_ver : "?",
+                      params->build_date ? params->build_date : "?");
+
+    case CMD_TELEM: {
+      char up[24];
+      _format_uptime(up, sizeof(up), params->uptime_secs);
+      int n = snprintf(reply, max_len, "Batt:%umV Up:%s", (unsigned)params->batt_mv, up);
+      if (params->mcu_temp == params->mcu_temp) {  // NAN != NAN
+        n += snprintf(reply + n, max_len - n, " MCU:%.1fC", (double)params->mcu_temp);
+      }
+      return n;
+    }
+
+    case CMD_FREQ: {
+      if (!*args) return snprintf(reply, max_len, "f:%.3f", (double)*params->freq);
+      float v = _cfg_atof(args);
+      if (v < 400.0f || v > 2500.0f) return snprintf(reply, max_len, "ERR freq 400-2500");
+      *params->freq = v;
+      actions->save_prefs(actions->ctx);
+      return snprintf(reply, max_len, "ok f=%.3f", (double)*params->freq);
+    }
+
+    case CMD_BW: {
+      if (!*args) return snprintf(reply, max_len, "b:%.1f", (double)*params->bw);
+      float v = _cfg_atof(args);
+      if (v < 7.8f || v > 500.0f) return snprintf(reply, max_len, "ERR bw 7.8-500");
+      *params->bw = v;
+      actions->save_prefs(actions->ctx);
+      return snprintf(reply, max_len, "ok b=%.1f", (double)*params->bw);
+    }
+
+    case CMD_SF: {
+      if (!*args) return snprintf(reply, max_len, "sf:%u", (unsigned)*params->sf);
+      uint32_t v = _cfg_atoi(args);
+      if (v < 5 || v > 12) return snprintf(reply, max_len, "ERR sf 5-12");
+      *params->sf = (uint8_t)v;
+      actions->save_prefs(actions->ctx);
+      return snprintf(reply, max_len, "ok sf=%u", (unsigned)*params->sf);
+    }
+
+    case CMD_CR: {
+      if (!*args) return snprintf(reply, max_len, "cr:%u", (unsigned)*params->cr);
+      uint32_t v = _cfg_atoi(args);
+      if (v < 5 || v > 8) return snprintf(reply, max_len, "ERR cr 5-8");
+      *params->cr = (uint8_t)v;
+      actions->save_prefs(actions->ctx);
+      return snprintf(reply, max_len, "ok cr=%u", (unsigned)*params->cr);
+    }
+
+    case CMD_POWER: {
+      if (!*args) return snprintf(reply, max_len, "p:%ddBm", (int)*params->tx_power_dbm);
+      int v = (*args == '-') ? -(int)_cfg_atoi(args + 1) : (int)_cfg_atoi(args);
+      if (v < -9 || v > 30) return snprintf(reply, max_len, "ERR power -9..30");
+      *params->tx_power_dbm = (int8_t)v;
+      actions->save_prefs(actions->ctx);
+      return snprintf(reply, max_len, "ok p=%ddBm", (int)*params->tx_power_dbm);
+    }
+
+    case CMD_NAME: {
+      if (!*args) return snprintf(reply, max_len, "n:%s", params->node_name);
+      int nlen = strlen(args);
+      if (nlen >= params->node_name_max) nlen = params->node_name_max - 1;
+      memcpy(params->node_name, args, nlen);
+      params->node_name[nlen] = 0;
+      actions->save_prefs(actions->ctx);
+      return snprintf(reply, max_len, "ok n=%s", params->node_name);
+    }
+
+    case CMD_REPEAT: {
+      if (!params->client_repeat) return snprintf(reply, max_len, "ERR n/a");
+      if (!*args) return snprintf(reply, max_len, "rpt:%s", *params->client_repeat ? "on" : "off");
+      if (_lower(args[0]) == 'o' && _lower(args[1]) == 'n') *params->client_repeat = 1;
+      else if (_lower(args[0]) == 'o' && _lower(args[1]) == 'f') *params->client_repeat = 0;
+      else return snprintf(reply, max_len, "ERR rep on|off");
+      actions->save_prefs(actions->ctx);
+      return snprintf(reply, max_len, "ok rpt=%s", *params->client_repeat ? "on" : "off");
+    }
+
+    case CMD_ADVERT: {
+      bool flood = (*args && _pmatch(args, _word_len(args, strlen(args)), "flood", 1));
+      actions->send_advert(actions->ctx, flood);
+      return snprintf(reply, max_len, "ok advert%s sent", flood ? " flood" : "");
+    }
+
+    case CMD_REBOOT:
+      actions->do_reboot(actions->ctx);
+      return snprintf(reply, max_len, "Rebooting...");
+
+    case CMD_AMBIGUOUS:
+      return snprintf(reply, max_len, "ERR ambiguous: reboot, repeat");
+
+    default:
+      return snprintf(reply, max_len, "ERR unknown. ? for help");
+  }
+}
+
+#endif
