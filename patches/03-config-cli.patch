+void MyMesh::initConfigChannel() {
+  // Check if config channel already exists (loaded from flash on previous boot)
+  for (int i = 0; i < MAX_GROUP_CHANNELS; i++) {
+    ChannelDetails cd;
+    if (getChannel(i, cd) && strcmp(cd.name, CONFIG_CHANNEL_NAME) == 0) {
+      _config_channel_idx = i;
+      MESH_DEBUG_PRINTLN("ConfigCLI: found existing config channel at idx=%d", i);
+      return;
+    }
+  }
+
+  // Not found — add it
+  auto ch = addChannel(CONFIG_CHANNEL_NAME, CONFIG_CHANNEL_PSK);
+  if (ch) {
+    _config_channel_idx = findChannelIdx(ch->channel);
+    MESH_DEBUG_PRINTLN("ConfigCLI: created config channel at idx=%d", _config_channel_idx);
+  } else {
+    _config_channel_idx = -1;
+    MESH_DEBUG_PRINTLN("ConfigCLI: ERROR failed to create config channel (channels full?)");
+  }
+}
+
+void MyMesh::handleConfigChannelMsg(const char* text, int text_len) {
+  ConfigCLIParams params;
+  fillConfigParams(params);
+
+  int rlen = configCLI_handleCommand(text, _cli_reply_buf, sizeof(_cli_reply_buf) - 1,
+                                     &params, &_cli_actions);
+  if (rlen > 0) {
+    _cli_reply_buf[rlen] = 0;
+    MESH_DEBUG_PRINTLN("ConfigCLI: reply len=%d", rlen);
+    pushConfigChannelReply(_cli_reply_buf);
+  } else {
+    MESH_DEBUG_PRINTLN("ConfigCLI: no reply for cmd");
+  }
+}
+
+void MyMesh::fillConfigParams(ConfigCLIParams& params) {
+  memset(&params, 0, sizeof(params));
+  params.node_name      = _prefs.node_name;
+  params.node_name_max  = sizeof(_prefs.node_name);
+  params.freq           = &_prefs.freq;
+  params.bw             = &_prefs.bw;
+  params.sf             = &_prefs.sf;
+  params.cr             = &_prefs.cr;
+  params.tx_power_dbm   = &_prefs.tx_power_dbm;
+  params.airtime_factor = &_prefs.airtime_factor;
+  params.client_repeat  = &_prefs.client_repeat;
+  params.batt_mv        = board.getBattMilliVolts();
+  params.uptime_secs    = millis() / 1000;
+  params.num_contacts   = getNumContacts();
+  params.free_queue     = _mgr->getFreeCount();
+  params.total_queue    = _mgr->getOutboundTotal();
+  params.total_air_secs = getTotalAirTime() / 1000;
+  params.rx_air_secs    = getReceiveAirTime() / 1000;
+  params.n_sent_flood   = getNumSentFlood();
+  params.n_sent_direct  = getNumSentDirect();
+  params.n_recv_flood   = getNumRecvFlood();
+  params.n_recv_direct  = getNumRecvDirect();
+  params.firmware_ver   = FIRMWARE_VERSION;
+  params.build_date     = FIRMWARE_BUILD_DATE;
+  params.mcu_temp       = board.getMCUTemperature();
+
+  _cli_actions.save_prefs  = _cfgSavePrefs;
+  _cli_actions.send_advert = _cfgSendAdvert;
+  _cli_actions.do_reboot   = _cfgReboot;
+  _cli_actions.ctx         = this;
+}
+
+void MyMesh::pushConfigChannelReply(const char* reply) {
+  int i = 0;
+  if (app_target_ver >= 3) {
+    out_frame[i++] = RESP_CODE_CHANNEL_MSG_RECV_V3;
+    out_frame[i++] = 0;  // SNR (n/a for local)
+    out_frame[i++] = 0;  // reserved
+    out_frame[i++] = 0;  // reserved
+  } else {
+    out_frame[i++] = RESP_CODE_CHANNEL_MSG_RECV;
+  }
+  out_frame[i++] = (uint8_t)_config_channel_idx;
+  out_frame[i++] = 0xFF;           // path_len = 0xFF means "direct"
+  out_frame[i++] = TXT_TYPE_PLAIN;
+  uint32_t now = getRTCClock()->getCurrentTime();
+  memcpy(&out_frame[i], &now, 4); i += 4;
+
+  // Prepend "config: " so it appears as a message from "config" in the channel
+  const char* prefix = CONFIG_CHANNEL_NAME ": ";
+  int plen = strlen(prefix);
+  if (i + plen < MAX_FRAME_SIZE) {
+    memcpy(&out_frame[i], prefix, plen); i += plen;
+  }
+
+  int tlen = strlen(reply);
+  if (i + tlen > MAX_FRAME_SIZE) tlen = MAX_FRAME_SIZE - i;
+  memcpy(&out_frame[i], reply, tlen); i += tlen;
+
+  addToOfflineQueue(out_frame, i);
+
+  if (_serial->isConnected()) {
+    uint8_t tickle[1] = { PUSH_CODE_MSG_WAITING };
+    _serial->writeFrame(tickle, 1);
+  }
+
+  MESH_DEBUG_PRINTLN("ConfigCLI: queued reply frame, len=%d", i);
+}
+
+void MyMesh::_cfgSavePrefs(void* ctx) {
+  ((MyMesh*)ctx)->savePrefs();
+  MESH_DEBUG_PRINTLN("ConfigCLI: prefs saved");
+}
+
+void MyMesh::_cfgSendAdvert(void* ctx, bool flood) {
+  auto m = (MyMesh*)ctx;
+  mesh::Packet* pkt;
+  if (m->_prefs.advert_loc_policy == ADVERT_LOC_NONE) {
+    pkt = m->createSelfAdvert(m->_prefs.node_name);
+  } else {
+    pkt = m->createSelfAdvert(m->_prefs.node_name, sensors.node_lat, sensors.node_lon);
+  }
+  if (pkt) {
+    if (flood) {
+      m->sendFlood(pkt, (uint32_t)0, (uint8_t)(m->_prefs.path_hash_mode + 1));
+    } else {
+      m->sendZeroHop(pkt);
+    }
+    MESH_DEBUG_PRINTLN("ConfigCLI: advert sent (flood=%d)", (int)flood);
+  } else {
+    MESH_DEBUG_PRINTLN("ConfigCLI: ERROR failed to create advert packet");
+  }
+}
+
+void MyMesh::_cfgReboot(void* ctx) {
+  auto m = (MyMesh*)ctx;
+  m->_cfg_reboot_at = millis() + 500;  // reboot in 500ms, after reply is delivered
+  MESH_DEBUG_PRINTLN("ConfigCLI: reboot scheduled in 500ms");
+}
