+#pragma once
+
+#ifdef CONFIG_CLI_ENABLED
+
+#include <stdint.h>
+#include <stddef.h>
+
+struct ConfigCLIParams {
+  // Read/write config (pointers to firmware's own storage)
+  char* node_name;
+  int node_name_max;          // sizeof(node_name) for bounds check
+  float* freq;
+  float* bw;
+  uint8_t* sf;
+  uint8_t* cr;
+  int8_t* tx_power_dbm;
+  float* airtime_factor;
+  uint8_t* client_repeat;     // companion forwarding toggle (NULL if not applicable)
+
+  // Read-only status (filled before each call)
+  uint16_t batt_mv;
+  uint32_t uptime_secs;
+  int num_contacts;
+  int free_queue;
+  int total_queue;
+  uint32_t total_air_secs;
+  uint32_t rx_air_secs;
+  uint32_t n_sent_flood;
+  uint32_t n_sent_direct;
+  uint32_t n_recv_flood;
+  uint32_t n_recv_direct;
+  const char* firmware_ver;
+  const char* build_date;
+  float mcu_temp;           // MCU temperature in C (NAN if unavailable)
+};
+
+struct ConfigCLIActions {
+  void (*save_prefs)(void* ctx);
+  void (*send_advert)(void* ctx, bool flood);
+  void (*do_reboot)(void* ctx);
+  void* ctx;
+};
+
+// Process a command, write reply into `reply` buffer.
+// `cmd` is the raw command text (sender prefix already stripped).
+// Returns length of reply, 0 if no output.
+int configCLI_handleCommand(const char* cmd, char* reply, int max_len,
+                            ConfigCLIParams* params, ConfigCLIActions* actions);
+
+#endif // CONFIG_CLI_ENABLED
