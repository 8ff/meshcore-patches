diff --git a/src/helpers/ConfigCLI.cpp b/src/helpers/ConfigCLI.cpp
new file mode 100644
index 0000000..c1926ac
--- /dev/null
+++ b/src/helpers/ConfigCLI.cpp
@@ -0,0 +1,306 @@
+#ifdef CONFIG_CLI_ENABLED
+
+#include "ConfigCLI.h"
+#include <string.h>
+#include <stdio.h>
+#include <MeshCore.h>  // for MESH_DEBUG_PRINTLN
+
+// Believe it or not, this std C function is busted on some platforms!
+static uint32_t _cfg_atoi(const char* sp) {
+  uint32_t n = 0;
+  while (*sp && *sp >= '0' && *sp <= '9') {
+    n *= 10;
+    n += (*sp++ - '0');
+  }
+  return n;
+}
+
+static float _cfg_atof(const char* sp) {
+  float result = 0.0f;
+  float sign = 1.0f;
+  if (*sp == '-') { sign = -1.0f; sp++; }
+
+  while (*sp >= '0' && *sp <= '9') {
+    result = result * 10.0f + (*sp++ - '0');
+  }
+  if (*sp == '.') {
+    sp++;
+    float frac = 0.1f;
+    while (*sp >= '0' && *sp <= '9') {
+      result += (*sp++ - '0') * frac;
+      frac *= 0.1f;
+    }
+  }
+  return result * sign;
+}
+
+// Skip leading whitespace
+static const char* _skip_ws(const char* s) {
+  while (*s == ' ' || *s == '\t') s++;
+  return s;
+}
+
+static void _format_uptime(char* buf, int max_len, uint32_t secs) {
+  uint32_t d = secs / 86400;
+  uint32_t h = (secs % 86400) / 3600;
+  uint32_t m = (secs % 3600) / 60;
+  if (d > 0) {
+    snprintf(buf, max_len, "%lud%luh%lum", (unsigned long)d, (unsigned long)h, (unsigned long)m);
+  } else if (h > 0) {
+    snprintf(buf, max_len, "%luh%lum", (unsigned long)h, (unsigned long)m);
+  } else {
+    snprintf(buf, max_len, "%lum", (unsigned long)m);
+  }
+}
+
+int configCLI_handleCommand(const char* cmd, char* reply, int max_len,
+                            ConfigCLIParams* params, ConfigCLIActions* actions) {
+  cmd = _skip_ws(cmd);
+  int len = strlen(cmd);
+
+  // Strip trailing whitespace/CR/LF
+  while (len > 0 && (cmd[len-1] == ' ' || cmd[len-1] == '\r' || cmd[len-1] == '\n' || cmd[len-1] == 0)) {
+    len--;
+  }
+  if (len == 0) return 0;  // empty command
+
+  // Lowercase command keywords in-place for case-insensitive matching.
+  // Safe: caller owns the buffer (cmd_frame) and null-terminated it.
+  // We lowercase everything EXCEPT the value after "set name " to preserve name case.
+  {
+    char* p = (char*)cmd;
+    // First, check if this is a "set name" command (case-insensitive check on first 9 chars)
+    bool is_set_name = (len > 9);
+    if (is_set_name) {
+      // Check "set name " with manual case-insensitive compare
+      const char* expect = "set name ";
+      for (int j = 0; j < 9; j++) {
+        char c = p[j];
+        if (c >= 'A' && c <= 'Z') c += 32;
+        if (c != expect[j]) { is_set_name = false; break; }
+      }
+    }
+    int lc_end = is_set_name ? 9 : len;
+    for (int j = 0; j < lc_end; j++) {
+      if (p[j] >= 'A' && p[j] <= 'Z') p[j] += 32;
+    }
+  }
+
+  MESH_DEBUG_PRINTLN("ConfigCLI: cmd='%.*s' len=%d", len, cmd, len);
+
+  // --- help ---
+  if ((len == 1 && cmd[0] == '?') || (len == 4 && memcmp(cmd, "help", 4) == 0)) {
+    return snprintf(reply, max_len,
+      "? status get config set <param> advert reboot | "
+      "help <cmd> for details");
+  }
+  if (len > 5 && memcmp(cmd, "help ", 5) == 0) {
+    const char* topic = _skip_ws(cmd + 5);
+    int tlen = strlen(topic);
+    // trim trailing whitespace from topic
+    while (tlen > 0 && topic[tlen-1] == ' ') tlen--;
+
+    if (tlen == 3 && memcmp(topic, "set", 3) == 0) {
+      return snprintf(reply, max_len,
+        "set name <text> | set freq <400-2500> | set bw <7.8-500> | "
+        "set sf <5-12> | set cr <5-8> | set power <-9 to 30>%s",
+        params->client_repeat ? " | set repeat <on|off>" : "");
+    }
+    if (tlen == 6 && memcmp(topic, "status", 6) == 0) {
+      return snprintf(reply, max_len,
+        "status: battery mV, uptime, airtime tx/rx, "
+        "packets sent/recv flood/direct, queue free/total, contacts");
+    }
+    if ((tlen == 3 && memcmp(topic, "get", 3) == 0) ||
+        (tlen == 6 && memcmp(topic, "config", 6) == 0) ||
+        (tlen == 10 && memcmp(topic, "get config", 10) == 0)) {
+      return snprintf(reply, max_len,
+        "get config: name, freq, bw, sf, cr, power, airtime factor%s, firmware ver",
+        params->client_repeat ? ", repeat" : "");
+    }
+    if (tlen == 6 && memcmp(topic, "advert", 6) == 0) {
+      return snprintf(reply, max_len,
+        "advert: send zero-hop advertisement | "
+        "advert flood: send flood advertisement to mesh");
+    }
+    if (tlen == 6 && memcmp(topic, "reboot", 6) == 0) {
+      return snprintf(reply, max_len, "reboot: restart device (500ms delay for reply delivery)");
+    }
+    if (tlen == 4 && memcmp(topic, "name", 4) == 0) {
+      return snprintf(reply, max_len, "set name <text>: node name, max %d chars", params->node_name_max - 1);
+    }
+    if (tlen == 4 && memcmp(topic, "freq", 4) == 0) {
+      return snprintf(reply, max_len, "set freq <MHz>: LoRa frequency, 400-2500 (current: %.3f)", (double)*params->freq);
+    }
+    if (tlen == 2 && memcmp(topic, "bw", 2) == 0) {
+      return snprintf(reply, max_len, "set bw <kHz>: bandwidth, 7.8-500 (current: %.1f)", (double)*params->bw);
+    }
+    if (tlen == 2 && memcmp(topic, "sf", 2) == 0) {
+      return snprintf(reply, max_len, "set sf <5-12>: spreading factor (current: %u)", (unsigned)*params->sf);
+    }
+    if (tlen == 2 && memcmp(topic, "cr", 2) == 0) {
+      return snprintf(reply, max_len, "set cr <5-8>: coding rate (current: %u)", (unsigned)*params->cr);
+    }
+    if (tlen == 5 && memcmp(topic, "power", 5) == 0) {
+      return snprintf(reply, max_len, "set power <dBm>: TX power, -9 to 30 (current: %d)", (int)*params->tx_power_dbm);
+    }
+    if (params->client_repeat && tlen == 6 && memcmp(topic, "repeat", 6) == 0) {
+      return snprintf(reply, max_len, "set repeat <on|off>: packet forwarding (current: %s)",
+                      *params->client_repeat ? "on" : "off");
+    }
+    return snprintf(reply, max_len, "Unknown topic. Try: help set, help status, help advert");
+  }
+
+  // --- status ---
+  if (len == 6 && memcmp(cmd, "status", 6) == 0) {
+    char uptime_buf[24];
+    _format_uptime(uptime_buf, sizeof(uptime_buf), params->uptime_secs);
+    return snprintf(reply, max_len,
+      "Batt: %umV  Up: %s  Air: %lus tx/%lus rx  "
+      "Pkts: %lu/%lu F %lu/%lu D  "
+      "Queue: %d/%d  Contacts: %d",
+      (unsigned)params->batt_mv, uptime_buf,
+      (unsigned long)params->total_air_secs, (unsigned long)params->rx_air_secs,
+      (unsigned long)params->n_sent_flood, (unsigned long)params->n_recv_flood,
+      (unsigned long)params->n_sent_direct, (unsigned long)params->n_recv_direct,
+      params->free_queue, params->total_queue, params->num_contacts);
+  }
+
+  // --- get config ---
+  if (len == 10 && memcmp(cmd, "get config", 10) == 0) {
+    int n = snprintf(reply, max_len,
+      "Name: %s  Freq: %.3f  BW: %.1f  SF: %u  CR: %u  "
+      "Power: %ddBm  Airtime: %.1f",
+      params->node_name,
+      (double)*params->freq, (double)*params->bw,
+      (unsigned)*params->sf, (unsigned)*params->cr,
+      (int)*params->tx_power_dbm, (double)*params->airtime_factor);
+    if (params->client_repeat && n < max_len - 20) {
+      n += snprintf(reply + n, max_len - n, "  Repeat: %s",
+                    *params->client_repeat ? "on" : "off");
+    }
+    if (n < max_len - 30) {
+      n += snprintf(reply + n, max_len - n, "  FW: %s (%s)",
+                    params->firmware_ver ? params->firmware_ver : "?",
+                    params->build_date ? params->build_date : "?");
+    }
+    return n;
+  }
+
+  // --- set commands ---
+  if (len > 4 && memcmp(cmd, "set ", 4) == 0) {
+    const char* arg = cmd + 4;
+    int arg_len = len - 4;
+
+    // set name <X>
+    if (arg_len > 5 && memcmp(arg, "name ", 5) == 0) {
+      const char* val = _skip_ws(arg + 5);
+      if (*val == 0) return snprintf(reply, max_len, "ERR name cannot be empty");
+      int nlen = strlen(val);
+      if (nlen >= params->node_name_max) nlen = params->node_name_max - 1;
+      memcpy(params->node_name, val, nlen);
+      params->node_name[nlen] = 0;
+      actions->save_prefs(actions->ctx);
+      MESH_DEBUG_PRINTLN("ConfigCLI: set name='%s'", params->node_name);
+      return snprintf(reply, max_len, "OK name=%s", params->node_name);
+    }
+
+    // set freq <X>
+    if (arg_len > 5 && memcmp(arg, "freq ", 5) == 0) {
+      float v = _cfg_atof(_skip_ws(arg + 5));
+      if (v < 400.0f || v > 2500.0f) return snprintf(reply, max_len, "ERR freq range 400-2500");
+      *params->freq = v;
+      actions->save_prefs(actions->ctx);
+      MESH_DEBUG_PRINTLN("ConfigCLI: set freq=%.3f", (double)v);
+      return snprintf(reply, max_len, "OK freq=%.3f", (double)*params->freq);
+    }
+
+    // set bw <X>
+    if (arg_len > 3 && memcmp(arg, "bw ", 3) == 0) {
+      float v = _cfg_atof(_skip_ws(arg + 3));
+      if (v < 7.8f || v > 500.0f) return snprintf(reply, max_len, "ERR bw range 7.8-500");
+      *params->bw = v;
+      actions->save_prefs(actions->ctx);
+      MESH_DEBUG_PRINTLN("ConfigCLI: set bw=%.1f", (double)v);
+      return snprintf(reply, max_len, "OK bw=%.1f", (double)*params->bw);
+    }
+
+    // set sf <X>
+    if (arg_len > 3 && memcmp(arg, "sf ", 3) == 0) {
+      uint32_t v = _cfg_atoi(_skip_ws(arg + 3));
+      if (v < 5 || v > 12) return snprintf(reply, max_len, "ERR sf range 5-12");
+      *params->sf = (uint8_t)v;
+      actions->save_prefs(actions->ctx);
+      MESH_DEBUG_PRINTLN("ConfigCLI: set sf=%u", (unsigned)v);
+      return snprintf(reply, max_len, "OK sf=%u", (unsigned)*params->sf);
+    }
+
+    // set cr <X>
+    if (arg_len > 3 && memcmp(arg, "cr ", 3) == 0) {
+      uint32_t v = _cfg_atoi(_skip_ws(arg + 3));
+      if (v < 5 || v > 8) return snprintf(reply, max_len, "ERR cr range 5-8");
+      *params->cr = (uint8_t)v;
+      actions->save_prefs(actions->ctx);
+      MESH_DEBUG_PRINTLN("ConfigCLI: set cr=%u", (unsigned)v);
+      return snprintf(reply, max_len, "OK cr=%u", (unsigned)*params->cr);
+    }
+
+    // set power <X>
+    if (arg_len > 6 && memcmp(arg, "power ", 6) == 0) {
+      int v = (int)_cfg_atoi(_skip_ws(arg + 6));
+      // Handle negative: check if first non-space char is '-'
+      const char* vp = _skip_ws(arg + 6);
+      if (*vp == '-') v = -(int)_cfg_atoi(vp + 1);
+      if (v < -9 || v > 30) return snprintf(reply, max_len, "ERR power range -9 to 30");
+      *params->tx_power_dbm = (int8_t)v;
+      actions->save_prefs(actions->ctx);
+      MESH_DEBUG_PRINTLN("ConfigCLI: set power=%d", v);
+      return snprintf(reply, max_len, "OK power=%ddBm", (int)*params->tx_power_dbm);
+    }
+
+    // set repeat <on|off>
+    if (params->client_repeat && arg_len > 7 && memcmp(arg, "repeat ", 7) == 0) {
+      const char* val = _skip_ws(arg + 7);
+      if (memcmp(val, "on", 2) == 0) {
+        *params->client_repeat = 1;
+      } else if (memcmp(val, "off", 3) == 0) {
+        *params->client_repeat = 0;
+      } else {
+        return snprintf(reply, max_len, "ERR use: set repeat on|off");
+      }
+      actions->save_prefs(actions->ctx);
+      MESH_DEBUG_PRINTLN("ConfigCLI: set repeat=%s", *params->client_repeat ? "on" : "off");
+      return snprintf(reply, max_len, "OK repeat=%s", *params->client_repeat ? "on" : "off");
+    }
+
+    return snprintf(reply, max_len, "ERR unknown setting. Type 'help'");
+  }
+
+  // --- advert ---
+  if (len == 6 && memcmp(cmd, "advert", 6) == 0) {
+    actions->send_advert(actions->ctx, false);
+    MESH_DEBUG_PRINTLN("ConfigCLI: advert sent");
+    return snprintf(reply, max_len, "OK advert sent");
+  }
+  if (len == 12 && memcmp(cmd, "advert flood", 12) == 0) {
+    actions->send_advert(actions->ctx, true);
+    MESH_DEBUG_PRINTLN("ConfigCLI: advert flood sent");
+    return snprintf(reply, max_len, "OK advert flood sent");
+  }
+
+  // --- reboot ---
+  if (len == 6 && memcmp(cmd, "reboot", 6) == 0) {
+    int n = snprintf(reply, max_len, "Rebooting...");
+    MESH_DEBUG_PRINTLN("ConfigCLI: reboot requested");
+    // Note: actual reboot happens after reply is sent (caller should flush first)
+    // We set a flag via the action callback; caller handles the timing
+    actions->do_reboot(actions->ctx);
+    return n;  // reply may not actually be delivered if reboot is immediate
+  }
+
+  // --- unknown ---
+  MESH_DEBUG_PRINTLN("ConfigCLI: unknown cmd '%.*s'", len, cmd);
+  return snprintf(reply, max_len, "ERR unknown command. Type 'help'");
+}
+
+#endif // CONFIG_CLI_ENABLED
